{
  "id": "/?source=pwa",
  "name": "Frigo Chef",
  "short_name": "Frigo Chef",
  "description": "Snap your fridge, get healthy recipes.",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone", "minimal-ui"],
  "tab_strip": {
    "home_tab": "auto",
    "new_tab_button": { "url": "/" }
  },
  "background_color": "#f9fafb",
  "theme_color": "#10b981",
  "orientation": "portrait",
  "categories": ["food", "lifestyle"],
  "scope": "/",
  "lang": "fr",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.frigochef.app",
      "id": "com.frigochef.app"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "scope_extensions": [
    { "origin": "*.fridge-ai-pczd.vercel.app" },
    { "origin": "*.vercel.app" }
  ],
  "shortcuts": [
    {
      "name": "Nouvelle Recette",
      "short_name": "Recette",
      "description": "Créer une nouvelle recette",
      "url": "/",
      "icons": [{ "src": "icon-192x192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+frigo",
      "url": "/?query=%s"
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "Frigo Chef",
      "description": "Widget pour Frigo Chef",
      "tag": "frigo-chef-widget",
      "ms_ac_template": "/",
      "data_url": "/",
      "type": "application/json",
      "screenshots": [
        {
          "src": "icon-512x512.png",
          "sizes": "512x512",
          "type": "image/png",
          "label": "Widget"
        }
      ],
      "icons": [
        {
          "src": "icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/"
  },
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Frigo Chef Web App"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Frigo Chef Mobile App"
    }
  ]
}
